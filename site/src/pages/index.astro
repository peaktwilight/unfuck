---
import Layout from '../layouts/Layout.astro';
import { ShieldAlert, AlertTriangle, AlertCircle, Info, Wrench, BadgeCheck, FileJson, Github, Copy, Check, ChevronDown, KeyRound, Eye, Code, Database, FileWarning, Search, Globe, Image, FileCode, Package, Timer, MessageSquare, Bug } from 'lucide-astro';
---

<Layout>
  <!-- ====== NAVBAR ====== -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-transparent transition-all duration-300" id="navbar">
    <div class="max-w-6xl mx-auto flex items-center justify-between px-4 py-3">
      <a href="/" class="font-mono font-black text-xl text-accent hover:opacity-80 transition-opacity">unfcked</a>
      <a
        href="https://github.com/peaktwilight/unfcked"
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-dim hover:text-white transition-colors"
        aria-label="GitHub"
      >
        <Github class="w-6 h-6" />
      </a>
    </div>
  </nav>

  <script>
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        navbar?.classList.add('bg-bg/80', 'backdrop-blur-lg', 'border-border');
      } else {
        navbar?.classList.remove('bg-bg/80', 'backdrop-blur-lg', 'border-border');
      }
    });
  </script>

  <!-- ====== HERO ====== -->
  <section class="relative min-h-screen flex flex-col items-center justify-center px-4 py-20 overflow-hidden">
    <!-- Background grid -->
    <div class="absolute inset-0 opacity-[0.03] bg-grid"></div>
    <!-- Radial glow behind title -->
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] bg-accent/5 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="relative z-10 text-center max-w-5xl mx-auto">
      <!-- Hero title -->
      <div class="relative inline-block">
        <h1 class="title-glow font-mono font-black text-[clamp(3rem,15vw,14rem)] leading-[0.85] tracking-tighter text-accent select-none mb-6 max-w-[90vw]">
          unfcked
        </h1>
      </div>
      <p class="text-xl md:text-2xl text-text-dim max-w-2xl mx-auto mb-6 font-medium leading-relaxed">
        Your vibe-coded app has <span class="text-accent font-bold">47 problems</span>.<br />
        Let's find all of them.
      </p>
      <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-accent/10 border border-accent/20 rounded-full text-accent text-xs font-mono mb-12">
        proudly vibe-coded
      </span>

      <!-- Terminal -->
      <div class="max-w-2xl mx-auto mb-12">
        <div class="bg-bg-terminal border border-border rounded-xl overflow-hidden shadow-2xl shadow-black/50">
          <!-- Terminal header -->
          <div class="flex items-center gap-2 px-4 py-3 bg-[#111] border-b border-border">
            <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
            <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
            <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
            <span class="ml-2 text-xs text-text-dim font-mono">terminal</span>
          </div>
          <!-- Terminal body -->
          <div class="p-3 sm:p-5 font-mono text-[11px] sm:text-sm leading-relaxed text-left" id="terminal">
            <div class="terminal-line text-text-dim" style="animation-delay: 0.2s">$ npx unfcked</div>
            <div class="terminal-line mt-3" style="animation-delay: 0.5s">
              <span class="text-text-dim">Project:</span> <span class="text-white font-semibold">my-app</span> <span class="text-text-dim">(Next.js)</span>
            </div>
            <div class="terminal-line" style="animation-delay: 0.6s">
              <span class="text-text-dim">Files scanned:</span> <span class="text-white">47</span>
            </div>
            <div class="terminal-line mt-3" style="animation-delay: 0.9s">
              <span class="inline-flex items-center gap-1"><ShieldAlert class="w-4 h-4 text-critical" /><span class="text-critical">CRITICAL</span></span> <span class="text-text-dim">&middot;</span> Hardcoded API key in <span class="text-white">src/config.ts:12</span>
            </div>
            <div class="terminal-line" style="animation-delay: 1.1s">
              <span class="inline-flex items-center gap-1"><ShieldAlert class="w-4 h-4 text-critical" /><span class="text-critical">CRITICAL</span></span> <span class="text-text-dim">&middot;</span> .env not in .gitignore
            </div>
            <div class="terminal-line mt-2" style="animation-delay: 1.3s">
              <span class="inline-flex items-center gap-1"><AlertTriangle class="w-4 h-4 text-high" /><span class="text-high">HIGH</span></span> <span class="text-text-dim">&middot;</span> Missing meta description
            </div>
            <div class="terminal-line" style="animation-delay: 1.45s">
              <span class="inline-flex items-center gap-1"><AlertTriangle class="w-4 h-4 text-high" /><span class="text-high">HIGH</span></span> <span class="text-text-dim">&middot;</span> No error boundary
            </div>
            <div class="terminal-line" style="animation-delay: 1.6s">
              <span class="inline-flex items-center gap-1"><AlertTriangle class="w-4 h-4 text-high" /><span class="text-high">HIGH</span></span> <span class="text-text-dim">&middot;</span> No loading states
            </div>
            <div class="terminal-line mt-2" style="animation-delay: 1.8s">
              <span class="inline-flex items-center gap-1"><AlertCircle class="w-4 h-4 text-medium" /><span class="text-medium">MEDIUM</span></span> <span class="text-text-dim">&middot;</span> 3 unused dependencies
            </div>
            <div class="terminal-line" style="animation-delay: 1.95s">
              <span class="inline-flex items-center gap-1"><AlertCircle class="w-4 h-4 text-medium" /><span class="text-medium">MEDIUM</span></span> <span class="text-text-dim">&middot;</span> Dev dependency in wrong section
            </div>
            <div class="terminal-line mt-2" style="animation-delay: 2.15s">
              <span class="inline-flex items-center gap-1"><Info class="w-4 h-4 text-low" /><span class="text-low">LOW</span></span> <span class="text-text-dim">&middot;</span> 12 console.log statements
            </div>
            <div class="terminal-line" style="animation-delay: 2.3s">
              <span class="inline-flex items-center gap-1"><Info class="w-4 h-4 text-low" /><span class="text-low">LOW</span></span> <span class="text-text-dim">&middot;</span> 3 TODO comments
            </div>
            <div class="terminal-line mt-4 pt-3 border-t border-border" style="animation-delay: 2.7s">
              <span class="text-text-dim">SCORE:</span>
              <span class="text-critical font-bold text-lg"> 34/100</span>
              <span class="text-text-dim"> &mdash; </span>
              <span class="text-critical font-bold">NEEDS WORK</span>
              <span class="terminal-cursor text-accent ml-1">&#x2588;</span>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <a
        href="https://github.com/peaktwilight/unfcked"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-accent hover:bg-accent-dim text-white font-bold text-lg px-8 py-4 rounded-xl transition-all duration-200 hover:scale-105 shadow-lg shadow-accent/20"
      >
        <Github class="w-6 h-6" />
        View on GitHub
      </a>
      <p class="text-text-dim font-mono text-sm mt-6">
        <a href="https://github.com/peaktwilight/unfcked" class="hover:text-white transition-colors">Star on GitHub</a>
        · Free & open source · No API keys needed · MIT License
      </p>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-text-dim animate-bounce">
      <ChevronDown class="w-6 h-6" />
    </div>
  </section>

  <!-- ====== THE VIBE CODING WALL ====== -->
  <section class="px-4 py-24 fade-up">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-mono font-bold text-3xl md:text-5xl mb-6 tracking-tight">The vibe coding wall</h2>
      <div class="space-y-5 text-text-dim text-lg leading-relaxed">
        <p>You prompted an AI. It built your app in 20 minutes. <span class="text-white font-semibold">It looks amazing.</span></p>
        <p>You show your friends. They're impressed. You feel like a 10x engineer.</p>
        <p>Then you deploy.</p>
        <p class="text-2xl md:text-3xl font-bold mt-4 mb-2"><span class="text-accent">And everything breaks.</span></p>
        <p class="text-sm text-text-dim/60 max-w-xl mx-auto">Hardcoded API keys pushed to GitHub. Missing error handling that crashes on first real user. No meta tags so Google can't find you. Dependencies you never asked for inflating your bundle. The AI got you 80% there — but the last 20% is where apps go to die.</p>
      </div>

      <blockquote class="border-l-4 border-accent pl-6 my-10 text-text-dim/70 italic text-left max-w-xl mx-auto">
        "Frustrated, currently vibe coding my friend's project since 2-3 hrs and AI not able to add single feature. Tired of giving prompts!!!!!"
        <footer class="text-xs mt-2 not-italic text-text-dim/40">&mdash; @danisshhh_h on X, March 2026</footer>
      </blockquote>

      <p class="text-text-dim text-sm">That wall is real. <span class="text-white font-semibold">unfcked</span> tells you exactly what's wrong — and fixes what it can.</p>
    </div>
  </section>

  <!-- ====== WHAT IT CATCHES ====== -->
  <section class="px-4 py-24 max-w-6xl mx-auto fade-up" id="catches">
    <h2 class="font-mono font-bold text-3xl md:text-5xl text-center mb-4 tracking-tight">What it catches</h2>
    <p class="text-text-dim text-center mb-16 text-lg">Every dumb mistake your AI pair programmer glossed over.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3 sm:gap-4">
      <!-- Critical -->
      <div class="bg-bg-card border border-border rounded-xl p-6 hover:border-critical/40 transition-colors max-sm:border-l-4 max-sm:border-l-critical">
        <div class="flex items-center gap-2 mb-4">
          <ShieldAlert class="w-6 h-6 text-critical" />
          <h3 class="font-mono font-bold text-critical text-lg">Critical</h3>
        </div>
        <ul class="space-y-2 text-sm text-text-dim">
          <li class="flex items-start gap-2"><KeyRound class="w-4 h-4 text-critical mt-0.5 shrink-0" /> Hardcoded secrets</li>
          <li class="flex items-start gap-2"><Eye class="w-4 h-4 text-critical mt-0.5 shrink-0" /> .env exposure</li>
          <li class="flex items-start gap-2"><Code class="w-4 h-4 text-critical mt-0.5 shrink-0" /> eval() usage</li>
          <li class="flex items-start gap-2"><FileCode class="w-4 h-4 text-critical mt-0.5 shrink-0" /> innerHTML injection</li>
          <li class="flex items-start gap-2"><Database class="w-4 h-4 text-critical mt-0.5 shrink-0" /> SQL injection</li>
        </ul>
      </div>

      <!-- High -->
      <div class="bg-bg-card border border-border rounded-xl p-6 hover:border-high/40 transition-colors max-sm:border-l-4 max-sm:border-l-high">
        <div class="flex items-center gap-2 mb-4">
          <AlertTriangle class="w-6 h-6 text-high" />
          <h3 class="font-mono font-bold text-high text-lg">High</h3>
        </div>
        <ul class="space-y-2 text-sm text-text-dim">
          <li class="flex items-start gap-2"><Globe class="w-4 h-4 text-high mt-0.5 shrink-0" /> Missing meta tags</li>
          <li class="flex items-start gap-2"><ShieldAlert class="w-4 h-4 text-high mt-0.5 shrink-0" /> No error boundary</li>
          <li class="flex items-start gap-2"><Timer class="w-4 h-4 text-high mt-0.5 shrink-0" /> No loading states</li>
          <li class="flex items-start gap-2"><Search class="w-4 h-4 text-high mt-0.5 shrink-0" /> No 404 page</li>
          <li class="flex items-start gap-2"><Image class="w-4 h-4 text-high mt-0.5 shrink-0" /> Missing favicon</li>
        </ul>
      </div>

      <!-- Medium -->
      <div class="bg-bg-card border border-border rounded-xl p-6 hover:border-medium/40 transition-colors max-sm:border-l-4 max-sm:border-l-medium">
        <div class="flex items-center gap-2 mb-4">
          <AlertCircle class="w-6 h-6 text-medium" />
          <h3 class="font-mono font-bold text-medium text-lg">Medium</h3>
        </div>
        <ul class="space-y-2 text-sm text-text-dim">
          <li class="flex items-start gap-2"><Package class="w-4 h-4 text-medium mt-0.5 shrink-0" /> Unused dependencies</li>
          <li class="flex items-start gap-2"><Package class="w-4 h-4 text-medium mt-0.5 shrink-0" /> Misplaced dev deps</li>
          <li class="flex items-start gap-2"><FileWarning class="w-4 h-4 text-medium mt-0.5 shrink-0" /> Stale lockfile</li>
        </ul>
      </div>

      <!-- Low -->
      <div class="bg-bg-card border border-border rounded-xl p-6 hover:border-low/40 transition-colors max-sm:border-l-4 max-sm:border-l-low">
        <div class="flex items-center gap-2 mb-4">
          <Info class="w-6 h-6 text-low" />
          <h3 class="font-mono font-bold text-low text-lg">Low</h3>
        </div>
        <ul class="space-y-2 text-sm text-text-dim">
          <li class="flex items-start gap-2"><MessageSquare class="w-4 h-4 text-low mt-0.5 shrink-0" /> console.log statements</li>
          <li class="flex items-start gap-2"><FileWarning class="w-4 h-4 text-low mt-0.5 shrink-0" /> TODO comments</li>
          <li class="flex items-start gap-2"><FileCode class="w-4 h-4 text-low mt-0.5 shrink-0" /> Long files</li>
          <li class="flex items-start gap-2"><Bug class="w-4 h-4 text-low mt-0.5 shrink-0" /> Silent catches</li>
          <li class="flex items-start gap-2"><Code class="w-4 h-4 text-low mt-0.5 shrink-0" /> <code class="text-text-dim">any</code> types</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ====== HALL OF SHAME ====== -->
  <section class="px-4 py-24 fade-up">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-mono font-bold text-3xl md:text-5xl text-center mb-4 tracking-tight">Hall of shame</h2>
      <p class="text-text-dim text-center mb-12 text-lg">We ran unfcked on popular vibe-coded projects.</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <!-- 23 - Generic SaaS Starter -->
        <div class="text-center p-6 bg-bg-card border border-border rounded-xl transition-all duration-200 hover:scale-105 hover:shadow-lg hover:shadow-black/40">
          <div class="font-mono text-4xl font-black text-critical">23</div>
          <div class="text-xs text-text-dim mt-1 font-semibold">Generic SaaS Starter</div>
          <div class="text-[10px] text-text-dim/50 font-mono mt-0.5">"my-saas-starter"</div>
          <div class="mt-3 space-y-1">
            <div class="flex items-center gap-1">
              <span class="text-[10px] text-text-dim w-6 text-right">4</span>
              <div class="flex-1 h-1.5 rounded-full bg-border overflow-hidden"><div class="h-full bg-critical rounded-full" style="width: 80%"></div></div>
            </div>
            <div class="flex items-center gap-1">
              <span class="text-[10px] text-text-dim w-6 text-right">7</span>
              <div class="flex-1 h-1.5 rounded-full bg-border overflow-hidden"><div class="h-full bg-high rounded-full" style="width: 70%"></div></div>
            </div>
            <div class="flex items-center gap-1">
              <span class="text-[10px] text-text-dim w-6 text-right">3</span>
              <div class="flex-1 h-1.5 rounded-full bg-border overflow-hidden"><div class="h-full bg-medium rounded-full" style="width: 40%"></div></div>
            </div>
            <div class="flex items-center gap-1">
              <span class="text-[10px] text-text-dim w-6 text-right">5</span>
              <div class="flex-1 h-1.5 rounded-full bg-border overflow-hidden"><div class="h-full bg-low rounded-full" style="width: 50%"></div></div>
            </div>
          </div>
        </div>

        <!-- 41 - AI Chat Template -->
        <div class="text-center p-6 bg-bg-card border border-border rounded-xl transition-all duration-200 hover:scale-105 hover:shadow-lg hover:shadow-black/40">
          <div class="font-mono text-4xl font-black text-high">41</div>
          <div class="text-xs text-text-dim mt-1 font-semibold">AI Chat Template</div>
          <div class="text-[10px] text-text-dim/50 font-mono mt-0.5">"ai-chat-template"</div>
          <div class="mt-3 space-y-1">
            <div class="flex items-center gap-1">
              <span class="text-[10px] text-text-dim w-6 text-right">2</span>
              <div class="flex-1 h-1.5 rounded-full bg-border overflow-hidden"><div class="h-full bg-critical rounded-full" style="width: 40%"></div></div>
            </div>
            <div class="flex items-center gap-1">
              <span class="text-[10px] text-text-dim w-6 text-right">5</span>
              <div class="flex-1 h-1.5 rounded-full bg-border overflow-hidden"><div class="h-full bg-high rounded-full" style="width: 50%"></div></div>
            </div>
            <div class="flex items-center gap-1">
              <span class="text-[10px] text-text-dim w-6 text-right">4</span>
              <div class="flex-1 h-1.5 rounded-full bg-border overflow-hidden"><div class="h-full bg-medium rounded-full" style="width: 55%"></div></div>
            </div>
            <div class="flex items-center gap-1">
              <span class="text-[10px] text-text-dim w-6 text-right">8</span>
              <div class="flex-1 h-1.5 rounded-full bg-border overflow-hidden"><div class="h-full bg-low rounded-full" style="width: 80%"></div></div>
            </div>
          </div>
        </div>

        <!-- 58 - Vibe-Coded Todo -->
        <div class="text-center p-6 bg-bg-card border border-border rounded-xl transition-all duration-200 hover:scale-105 hover:shadow-lg hover:shadow-black/40">
          <div class="font-mono text-4xl font-black text-medium">58</div>
          <div class="text-xs text-text-dim mt-1 font-semibold">Vibe-Coded Todo</div>
          <div class="text-[10px] text-text-dim/50 font-mono mt-0.5">"vibe-coded-todo"</div>
          <div class="mt-3 space-y-1">
            <div class="flex items-center gap-1">
              <span class="text-[10px] text-text-dim w-6 text-right">1</span>
              <div class="flex-1 h-1.5 rounded-full bg-border overflow-hidden"><div class="h-full bg-critical rounded-full" style="width: 20%"></div></div>
            </div>
            <div class="flex items-center gap-1">
              <span class="text-[10px] text-text-dim w-6 text-right">3</span>
              <div class="flex-1 h-1.5 rounded-full bg-border overflow-hidden"><div class="h-full bg-high rounded-full" style="width: 30%"></div></div>
            </div>
            <div class="flex items-center gap-1">
              <span class="text-[10px] text-text-dim w-6 text-right">2</span>
              <div class="flex-1 h-1.5 rounded-full bg-border overflow-hidden"><div class="h-full bg-medium rounded-full" style="width: 25%"></div></div>
            </div>
            <div class="flex items-center gap-1">
              <span class="text-[10px] text-text-dim w-6 text-right">6</span>
              <div class="flex-1 h-1.5 rounded-full bg-border overflow-hidden"><div class="h-full bg-low rounded-full" style="width: 60%"></div></div>
            </div>
          </div>
        </div>

        <!-- 94 - Hand-Crafted With Love -->
        <div class="text-center p-6 bg-bg-card border border-border rounded-xl hall-of-fame-glow relative transition-all duration-200 hover:scale-105">
          <div class="font-mono text-4xl font-black text-green">94</div>
          <div class="text-xs text-text-dim mt-1 font-semibold">Hand-Crafted With Love</div>
          <div class="text-[10px] text-text-dim/50 font-mono mt-0.5">"hand-crafted-with-love"</div>
          <div class="mt-3 space-y-1">
            <div class="flex items-center gap-1">
              <span class="text-[10px] text-text-dim w-6 text-right">0</span>
              <div class="flex-1 h-1.5 rounded-full bg-border overflow-hidden"><div class="h-full bg-critical rounded-full" style="width: 0%"></div></div>
            </div>
            <div class="flex items-center gap-1">
              <span class="text-[10px] text-text-dim w-6 text-right">0</span>
              <div class="flex-1 h-1.5 rounded-full bg-border overflow-hidden"><div class="h-full bg-high rounded-full" style="width: 0%"></div></div>
            </div>
            <div class="flex items-center gap-1">
              <span class="text-[10px] text-text-dim w-6 text-right">1</span>
              <div class="flex-1 h-1.5 rounded-full bg-border overflow-hidden"><div class="h-full bg-medium rounded-full" style="width: 15%"></div></div>
            </div>
            <div class="flex items-center gap-1">
              <span class="text-[10px] text-text-dim w-6 text-right">2</span>
              <div class="flex-1 h-1.5 rounded-full bg-border overflow-hidden"><div class="h-full bg-low rounded-full" style="width: 20%"></div></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== POWER FEATURES ====== -->
  <section class="px-4 py-24 fade-up">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-mono font-bold text-3xl md:text-5xl text-center mb-4 tracking-tight">Power features</h2>
      <p class="text-text-dim text-center mb-16 text-lg">Not just a linter. A fixer.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- --fix -->
        <div class="bg-bg-card border border-border rounded-xl p-8 hover:border-accent/30 transition-colors group">
          <div class="flex items-center gap-3 mb-3">
            <Wrench class="w-6 h-6 text-accent" />
            <span class="font-mono text-accent text-2xl font-bold">--fix</span>
          </div>
          <h3 class="font-bold text-xl mb-2 text-white">Auto-fix mode</h3>
          <p class="text-text-dim text-sm leading-relaxed">
            Fixes safe issues automatically. Removes console.logs, adds .gitignore entries, cleans up deps. Shows before/after score.
          </p>
          <div class="mt-4 font-mono text-xs text-text-dim bg-bg-terminal rounded-lg p-3 border border-border">
            <span class="text-critical">34</span><span class="text-text-dim">/100 &rarr; </span><span class="text-green">72</span><span class="text-text-dim">/100</span>
          </div>
        </div>

        <!-- --badge -->
        <div class="bg-bg-card border border-border rounded-xl p-8 hover:border-accent/30 transition-colors group">
          <div class="flex items-center gap-3 mb-3">
            <BadgeCheck class="w-6 h-6 text-accent" />
            <span class="font-mono text-accent text-2xl font-bold">--badge</span>
          </div>
          <h3 class="font-bold text-xl mb-2 text-white">README badge</h3>
          <p class="text-text-dim text-sm leading-relaxed">
            Generate a shields.io badge for your README. Show the world your project isn't a dumpster fire.
          </p>
          <div class="mt-4 flex justify-center">
            <div class="inline-flex rounded overflow-hidden text-xs font-mono font-semibold">
              <span class="bg-[#555] text-white px-2.5 py-1">unfcked score</span>
              <span class="bg-green text-white px-2.5 py-1">92/100</span>
            </div>
          </div>
        </div>

        <!-- --json -->
        <div class="bg-bg-card border border-border rounded-xl p-8 hover:border-accent/30 transition-colors group">
          <div class="flex items-center gap-3 mb-3">
            <FileJson class="w-6 h-6 text-accent" />

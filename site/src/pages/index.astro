---
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <!-- ====== NAVBAR ====== -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-transparent transition-all duration-300" id="navbar">
    <div class="max-w-6xl mx-auto flex items-center justify-between px-4 py-3">
      <a href="/" class="font-mono font-black text-xl text-accent hover:opacity-80 transition-opacity">unfuck</a>
      <a
        href="https://github.com/peaktwilight/unfuck"
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-dim hover:text-white transition-colors"
        aria-label="GitHub"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
      </a>
    </div>
  </nav>

  <script>
    const navbar = document.getElementById('navbar');
    window.addEventListener('scroll', () => {
      if (window.scrollY > 20) {
        navbar?.classList.add('bg-bg/80', 'backdrop-blur-lg', 'border-border');
      } else {
        navbar?.classList.remove('bg-bg/80', 'backdrop-blur-lg', 'border-border');
      }
    });
  </script>

  <!-- ====== HERO ====== -->
  <section class="relative min-h-screen flex flex-col items-center justify-center px-4 py-20 overflow-hidden">
    <!-- Background grid -->
    <div class="absolute inset-0 opacity-[0.03] bg-grid"></div>
    <!-- Radial glow behind title -->
    <div class="absolute top-1/4 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[600px] bg-accent/5 rounded-full blur-[120px] pointer-events-none"></div>

    <div class="relative z-10 text-center max-w-5xl mx-auto">
      <h1 class="title-glow font-mono font-black text-[clamp(4rem,15vw,10rem)] leading-[0.9] tracking-tighter text-accent select-none mb-6">
        unfuck
      </h1>
      <p class="text-xl md:text-2xl text-text-dim max-w-2xl mx-auto mb-12 font-medium leading-relaxed">
        Your vibe-coded app has <span class="text-accent font-bold">47 problems</span>.<br />
        Let's find all of them.
      </p>

      <!-- Terminal -->
      <div class="max-w-2xl mx-auto mb-12">
        <div class="bg-bg-terminal border border-border rounded-xl overflow-hidden shadow-2xl shadow-black/50">
          <!-- Terminal header -->
          <div class="flex items-center gap-2 px-4 py-3 bg-[#111] border-b border-border">
            <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
            <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
            <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
            <span class="ml-2 text-xs text-text-dim font-mono">terminal</span>
          </div>
          <!-- Terminal body -->
          <div class="p-5 font-mono text-sm leading-relaxed text-left" id="terminal">
            <div class="terminal-line text-text-dim" style="animation-delay: 0.2s">$ npx unfuck</div>
            <div class="terminal-line mt-3" style="animation-delay: 0.5s">
              <span class="text-text-dim">Project:</span> <span class="text-white font-semibold">my-app</span> <span class="text-text-dim">(Next.js)</span>
            </div>
            <div class="terminal-line" style="animation-delay: 0.6s">
              <span class="text-text-dim">Files scanned:</span> <span class="text-white">47</span>
            </div>
            <div class="terminal-line mt-3" style="animation-delay: 0.9s">
              <span class="text-critical">&#x1F534; CRITICAL</span> <span class="text-text-dim">&#xB7;</span> Hardcoded API key in <span class="text-white">src/config.ts:12</span>
            </div>
            <div class="terminal-line" style="animation-delay: 1.1s">
              <span class="text-critical">&#x1F534; CRITICAL</span> <span class="text-text-dim">&#xB7;</span> .env not in .gitignore
            </div>
            <div class="terminal-line mt-2" style="animation-delay: 1.3s">
              <span class="text-high">&#x1F7E0; HIGH</span> <span class="text-text-dim">&#xB7;</span> Missing meta description
            </div>
            <div class="terminal-line" style="animation-delay: 1.45s">
              <span class="text-high">&#x1F7E0; HIGH</span> <span class="text-text-dim">&#xB7;</span> No error boundary
            </div>
            <div class="terminal-line" style="animation-delay: 1.6s">
              <span class="text-high">&#x1F7E0; HIGH</span> <span class="text-text-dim">&#xB7;</span> No loading states
            </div>
            <div class="terminal-line mt-2" style="animation-delay: 1.8s">
              <span class="text-medium">&#x1F7E1; MEDIUM</span> <span class="text-text-dim">&#xB7;</span> 3 unused dependencies
            </div>
            <div class="terminal-line" style="animation-delay: 1.95s">
              <span class="text-medium">&#x1F7E1; MEDIUM</span> <span class="text-text-dim">&#xB7;</span> Dev dependency in wrong section
            </div>
            <div class="terminal-line mt-2" style="animation-delay: 2.15s">
              <span class="text-low">&#x1F535; LOW</span> <span class="text-text-dim">&#xB7;</span> 12 console.log statements
            </div>
            <div class="terminal-line" style="animation-delay: 2.3s">
              <span class="text-low">&#x1F535; LOW</span> <span class="text-text-dim">&#xB7;</span> 3 TODO comments
            </div>
            <div class="terminal-line mt-4 pt-3 border-t border-border" style="animation-delay: 2.7s">
              <span class="text-text-dim">SCORE:</span>
              <span class="text-critical font-bold text-lg"> 34/100</span>
              <span class="text-text-dim"> &mdash; </span>
              <span class="text-critical font-bold">NEEDS WORK</span>
              <span class="terminal-cursor text-accent ml-1">&#x2588;</span>
            </div>
          </div>
        </div>
      </div>

      <!-- CTA -->
      <a
        href="https://github.com/peaktwilight/unfuck"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-3 bg-accent hover:bg-accent-dim text-white font-bold text-lg px-8 py-4 rounded-xl transition-all duration-200 hover:scale-105 shadow-lg shadow-accent/20"
      >
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"/></svg>
        View on GitHub
      </a>
      <p class="text-text-dim font-mono text-sm mt-6">
        <a href="https://github.com/peaktwilight/unfuck" class="hover:text-white transition-colors">Star on GitHub</a>
        · Free & open source · No API keys needed · MIT License
      </p>
    </div>

    <!-- Scroll hint -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-text-dim animate-bounce">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
    </div>
  </section>

  <!-- ====== THE VIBE CODING WALL ====== -->
  <section class="px-4 py-24 fade-up">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-mono font-bold text-3xl md:text-5xl mb-6 tracking-tight">The vibe coding wall</h2>
      <div class="space-y-4 text-text-dim text-lg leading-relaxed">
        <p>You prompted an AI. It built your app in 20 minutes. <span class="text-white font-semibold">It looks amazing.</span></p>
        <p>Then you deploy. <span class="text-accent font-bold">And everything breaks.</span></p>
        <p class="text-sm text-text-dim/60">Hardcoded secrets. Missing error handling. No meta tags. Dependencies you never asked for. The AI got you 80% there — but the last 20% is where careers end.</p>
      </div>
    </div>
  </section>

  <!-- ====== WHAT IT CATCHES ====== -->
  <section class="px-4 py-24 max-w-6xl mx-auto fade-up" id="catches">
    <h2 class="font-mono font-bold text-3xl md:text-5xl text-center mb-4 tracking-tight">What it catches</h2>
    <p class="text-text-dim text-center mb-16 text-lg">Every dumb mistake your AI pair programmer glossed over.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      <!-- Critical -->
      <div class="bg-bg-card border border-border rounded-xl p-6 hover:border-critical/40 transition-colors">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl">&#x1F534;</span>
          <h3 class="font-mono font-bold text-critical text-lg">Critical</h3>
        </div>
        <ul class="space-y-2 text-sm text-text-dim">
          <li class="flex items-start gap-2"><span class="text-critical mt-0.5">&#x25CF;</span> Hardcoded secrets</li>
          <li class="flex items-start gap-2"><span class="text-critical mt-0.5">&#x25CF;</span> .env exposure</li>
          <li class="flex items-start gap-2"><span class="text-critical mt-0.5">&#x25CF;</span> eval() usage</li>
          <li class="flex items-start gap-2"><span class="text-critical mt-0.5">&#x25CF;</span> innerHTML injection</li>
          <li class="flex items-start gap-2"><span class="text-critical mt-0.5">&#x25CF;</span> SQL injection</li>
        </ul>
      </div>

      <!-- High -->
      <div class="bg-bg-card border border-border rounded-xl p-6 hover:border-high/40 transition-colors">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl">&#x1F7E0;</span>
          <h3 class="font-mono font-bold text-high text-lg">High</h3>
        </div>
        <ul class="space-y-2 text-sm text-text-dim">
          <li class="flex items-start gap-2"><span class="text-high mt-0.5">&#x25CF;</span> Missing meta tags</li>
          <li class="flex items-start gap-2"><span class="text-high mt-0.5">&#x25CF;</span> No error boundary</li>
          <li class="flex items-start gap-2"><span class="text-high mt-0.5">&#x25CF;</span> No loading states</li>
          <li class="flex items-start gap-2"><span class="text-high mt-0.5">&#x25CF;</span> No 404 page</li>
          <li class="flex items-start gap-2"><span class="text-high mt-0.5">&#x25CF;</span> Missing favicon</li>
        </ul>
      </div>

      <!-- Medium -->
      <div class="bg-bg-card border border-border rounded-xl p-6 hover:border-medium/40 transition-colors">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl">&#x1F7E1;</span>
          <h3 class="font-mono font-bold text-medium text-lg">Medium</h3>
        </div>
        <ul class="space-y-2 text-sm text-text-dim">
          <li class="flex items-start gap-2"><span class="text-medium mt-0.5">&#x25CF;</span> Unused dependencies</li>
          <li class="flex items-start gap-2"><span class="text-medium mt-0.5">&#x25CF;</span> Misplaced dev deps</li>
          <li class="flex items-start gap-2"><span class="text-medium mt-0.5">&#x25CF;</span> Stale lockfile</li>
        </ul>
      </div>

      <!-- Low -->
      <div class="bg-bg-card border border-border rounded-xl p-6 hover:border-low/40 transition-colors">
        <div class="flex items-center gap-2 mb-4">
          <span class="text-2xl">&#x1F535;</span>
          <h3 class="font-mono font-bold text-low text-lg">Low</h3>
        </div>
        <ul class="space-y-2 text-sm text-text-dim">
          <li class="flex items-start gap-2"><span class="text-low mt-0.5">&#x25CF;</span> console.log statements</li>
          <li class="flex items-start gap-2"><span class="text-low mt-0.5">&#x25CF;</span> TODO comments</li>
          <li class="flex items-start gap-2"><span class="text-low mt-0.5">&#x25CF;</span> Long files</li>
          <li class="flex items-start gap-2"><span class="text-low mt-0.5">&#x25CF;</span> Silent catches</li>
          <li class="flex items-start gap-2"><span class="text-low mt-0.5">&#x25CF;</span> <code class="text-text-dim">any</code> types</li>
        </ul>
      </div>
    </div>
  </section>

  <!-- ====== HALL OF SHAME ====== -->
  <section class="px-4 py-24 fade-up">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-mono font-bold text-3xl md:text-5xl text-center mb-4 tracking-tight">Hall of shame</h2>
      <p class="text-text-dim text-center mb-12 text-lg">We ran unfuck on popular vibe-coded projects.</p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        <div class="text-center p-4 bg-bg-card border border-border rounded-xl">
          <div class="font-mono text-2xl font-black text-critical">23</div>
          <div class="text-xs text-text-dim mt-1">"my-saas-starter"</div>
        </div>
        <div class="text-center p-4 bg-bg-card border border-border rounded-xl">
          <div class="font-mono text-2xl font-black text-high">41</div>
          <div class="text-xs text-text-dim mt-1">"ai-chat-template"</div>
        </div>
        <div class="text-center p-4 bg-bg-card border border-border rounded-xl">
          <div class="font-mono text-2xl font-black text-medium">58</div>
          <div class="text-xs text-text-dim mt-1">"vibe-coded-todo"</div>
        </div>
        <div class="text-center p-4 bg-bg-card border border-border rounded-xl">
          <div class="font-mono text-2xl font-black text-green">94</div>
          <div class="text-xs text-text-dim mt-1">"hand-crafted-with-love"</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== POWER FEATURES ====== -->
  <section class="px-4 py-24 fade-up">
    <div class="max-w-5xl mx-auto">
      <h2 class="font-mono font-bold text-3xl md:text-5xl text-center mb-4 tracking-tight">Power features</h2>
      <p class="text-text-dim text-center mb-16 text-lg">Not just a linter. A fixer.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- --fix -->
        <div class="bg-bg-card border border-border rounded-xl p-8 hover:border-accent/30 transition-colors group">
          <div class="font-mono text-accent text-2xl font-bold mb-3">--fix</div>
          <h3 class="font-bold text-xl mb-2 text-white">Auto-fix mode</h3>
          <p class="text-text-dim text-sm leading-relaxed">
            Fixes safe issues automatically. Removes console.logs, adds .gitignore entries, cleans up deps. Shows before/after score.
          </p>
          <div class="mt-4 font-mono text-xs text-text-dim bg-bg-terminal rounded-lg p-3 border border-border">
            <span class="text-critical">34</span><span class="text-text-dim">/100 &rarr; </span><span class="text-green">72</span><span class="text-text-dim">/100</span>
          </div>
        </div>

        <!-- --badge -->
        <div class="bg-bg-card border border-border rounded-xl p-8 hover:border-accent/30 transition-colors group">
          <div class="font-mono text-accent text-2xl font-bold mb-3">--badge</div>
          <h3 class="font-bold text-xl mb-2 text-white">README badge</h3>
          <p class="text-text-dim text-sm leading-relaxed">
            Generate a shields.io badge for your README. Show the world your project isn't a dumpster fire.
          </p>
          <div class="mt-4 flex justify-center">
            <div class="inline-flex rounded overflow-hidden text-xs font-mono font-semibold">
              <span class="bg-[#555] text-white px-2.5 py-1">unfuck score</span>
              <span class="bg-green text-white px-2.5 py-1">92/100</span>
            </div>
          </div>
        </div>

        <!-- --json -->
        <div class="bg-bg-card border border-border rounded-xl p-8 hover:border-accent/30 transition-colors group">
          <div class="font-mono text-accent text-2xl font-bold mb-3">--json</div>
          <h3 class="font-bold text-xl mb-2 text-white">Machine output</h3>
          <p class="text-text-dim text-sm leading-relaxed">
            Pipe it to other tools. CI/CD integration. Build dashboards. Feed it to another AI, we won't judge.
          </p>
          <div class="mt-4 font-mono text-xs text-text-dim bg-bg-terminal rounded-lg p-3 border border-border">
            {'{"score": 34, "issues": 12}'}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== THE MATH ====== -->
  <section class="px-4 py-24 fade-up">
    <div class="max-w-4xl mx-auto">
      <h2 class="font-mono font-bold text-3xl md:text-5xl text-center mb-4 tracking-tight">The math</h2>
      <p class="text-text-dim text-center mb-16 text-lg">Start at 100. Every issue costs you.</p>

      <!-- Scoring breakdown -->
      <div class="bg-bg-card border border-border rounded-xl p-8 mb-12">
        <div class="grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
          <div>
            <div class="font-mono text-3xl font-black text-critical mb-1">-20</div>
            <div class="text-xs text-text-dim uppercase tracking-wider font-semibold">Critical</div>
          </div>
          <div>
            <div class="font-mono text-3xl font-black text-high mb-1">-10</div>
            <div class="text-xs text-text-dim uppercase tracking-wider font-semibold">High</div>
          </div>
          <div>
            <div class="font-mono text-3xl font-black text-medium mb-1">-5</div>
            <div class="text-xs text-text-dim uppercase tracking-wider font-semibold">Medium</div>
          </div>
          <div>
            <div class="font-mono text-3xl font-black text-low mb-1">-2</div>
            <div class="text-xs text-text-dim uppercase tracking-wider font-semibold">Low</div>
          </div>
        </div>
      </div>

      <!-- Verdict scale -->
      <div class="space-y-3">
        <div class="flex items-center gap-4">
          <div class="w-24 text-right font-mono text-sm font-bold text-green">90-100</div>
          <div class="flex-1 h-8 rounded-lg bg-green/20 border border-green/30 flex items-center px-4">
            <span class="font-mono text-sm font-bold text-green">CERTIFIED CLEAN</span>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <div class="w-24 text-right font-mono text-sm font-bold text-low">70-89</div>
          <div class="flex-1 h-8 rounded-lg bg-low/20 border border-low/30 flex items-center px-4">
            <span class="font-mono text-sm font-bold text-low">LOOKING GOOD</span>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <div class="w-24 text-right font-mono text-sm font-bold text-medium">50-69</div>
          <div class="flex-1 h-8 rounded-lg bg-medium/20 border border-medium/30 flex items-center px-4">
            <span class="font-mono text-sm font-bold text-medium">NEEDS WORK</span>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <div class="w-24 text-right font-mono text-sm font-bold text-high">25-49</div>
          <div class="flex-1 h-8 rounded-lg bg-high/20 border border-high/30 flex items-center px-4">
            <span class="font-mono text-sm font-bold text-high">YIKES</span>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <div class="w-24 text-right font-mono text-sm font-bold text-critical">0-24</div>
          <div class="flex-1 h-8 rounded-lg bg-critical/20 border border-critical/30 flex items-center px-4">
            <span class="font-mono text-sm font-bold text-critical">DUMPSTER FIRE</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== QUICK START ====== -->
  <section class="px-4 py-24 fade-up">
    <div class="max-w-3xl mx-auto">
      <h2 class="font-mono font-bold text-3xl md:text-5xl text-center mb-4 tracking-tight">Quick start</h2>
      <p class="text-text-dim text-center mb-12 text-lg">One command. Zero config.</p>

      <div class="bg-bg-terminal border border-border rounded-xl overflow-hidden">
        <div class="flex items-center gap-2 px-4 py-3 bg-[#111] border-b border-border">
          <div class="w-3 h-3 rounded-full bg-[#ff5f57]"></div>
          <div class="w-3 h-3 rounded-full bg-[#febc2e]"></div>
          <div class="w-3 h-3 rounded-full bg-[#28c840]"></div>
        </div>
        <div class="p-6 font-mono text-sm leading-loose">
          <div class="text-text-dim"># Clone and build</div>
          <div><span class="text-accent">$</span> git clone https://github.com/peaktwilight/unfuck</div>
          <div><span class="text-accent">$</span> cd unfuck && npm install && npm run build</div>
          <div class="mt-4 text-text-dim"># Scan any project</div>
          <div><span class="text-accent">$</span> node dist/cli.js /path/to/your/project</div>
          <div class="mt-4 text-text-dim"># Auto-fix safe issues</div>
          <div><span class="text-accent">$</span> node dist/cli.js --fix /path/to/your/project</div>
          <div class="mt-4 text-text-dim"># Get a README badge</div>
          <div><span class="text-accent">$</span> node dist/cli.js --badge /path/to/your/project</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ====== SOCIAL SHARING ====== -->
  <section class="px-4 py-24 fade-up">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="font-mono font-bold text-3xl md:text-5xl mb-4 tracking-tight">Share the unfuckery</h2>
      <p class="text-text-dim mb-8 text-lg">Let others know their vibe-coded projects need help.</p>

      } else {
        pasteTab.className = 'text-xs font-mono text-accent border-b border-accent pb-0.5 transition-colors cursor-pointer';
        ghTab.className = 'text-xs font-mono text-text-dim hover:text-white pb-0.5 border-b border-transparent transition-colors cursor-pointer';
        pastePanel.classList.remove('hidden');
        ghPanel.classList.add('hidden');
      }
    }

    function renderResults(issues, title) {
      var results = document.getElementById('scan-results');
      results.classList.remove('hidden');

      var score = 100;
      issues.forEach(function(i) {
        if (i.severity === 'critical') score -= 20;
        if (i.severity === 'high') score -= 10;
        if (i.severity === 'medium') score -= 5;
        if (i.severity === 'low') score -= 2;
      });
      score = Math.max(0, score);

      var colors = { critical: 'text-red-400', high: 'text-orange-400', medium: 'text-yellow-400', low: 'text-blue-400' };
      var labels = { critical: 'CRITICAL', high: 'HIGH', medium: 'MEDIUM', low: 'LOW' };

      var verdict, verdictColor;
      if (score >= 90) { verdict = 'CERTIFIED CLEAN'; verdictColor = 'text-green-400'; }
      else if (score >= 70) { verdict = 'MOSTLY GOOD'; verdictColor = 'text-green-400'; }
      else if (score >= 50) { verdict = 'NEEDS WORK'; verdictColor = 'text-yellow-400'; }
      else if (score >= 30) { verdict = 'PRETTY ROUGH'; verdictColor = 'text-orange-400'; }
      else { verdict = 'DUMPSTER FIRE'; verdictColor = 'text-red-400'; }

      var html = '<div class="mb-4 text-white font-bold">' + title + '</div>';

      if (issues.length === 0) {
        html += '<p class="text-green-400 mb-4">No issues found. Impressive.</p>';
      } else {
        html += issues.map(function(i) {
          return '<div class="flex items-start gap-2 mb-2"><span class="' + colors[i.severity] + ' font-bold text-xs shrink-0">' + labels[i.severity] + '</span> <span class="text-gray-300">' + i.text + '</span></div>';
        }).join('');
      }

      html += '<div class="mt-4 pt-4 border-t border-gray-800"><span class="text-text-dim">Score:</span> <span class="' + verdictColor + ' font-bold text-lg">' + score + '/100</span> <span class="text-text-dim">\u2014</span> <span class="' + verdictColor + ' font-bold">' + verdict + '</span></div>';
      html += '<p class="text-text-dim/50 text-xs mt-3">This scans key files only. Run <code class="text-accent">npx unfcked</code> for the full 45+ check deep scan.</p>';

      results.innerHTML = html;
    }

    function checkPackageJson(pkgRaw, issues) {
      try {
        var pkg = JSON.parse(pkgRaw);
        var deps = Object.keys(pkg.dependencies || {});
        var scripts = pkg.scripts || {};

        var devInProd = ['typescript','eslint','prettier','jest','vitest','mocha','chai','webpack','vite','rollup','esbuild','nodemon','ts-node','ts-jest'];
        var typesInProd = deps.filter(function(d) { return d.startsWith('@types/'); });
        var misplaced = deps.filter(function(d) { return devInProd.indexOf(d) !== -1; });
        if (misplaced.length > 0 || typesInProd.length > 0) {
          issues.push({ severity: 'medium', text: 'Dev dependencies in "dependencies": ' + misplaced.concat(typesInProd).join(', ') });
        }

        if (deps.length > 30) issues.push({ severity: 'medium', text: deps.length + ' production dependencies \u2014 check for unused ones' });
        if (!scripts.build) issues.push({ severity: 'high', text: 'No "build" script' });
        if (!scripts.start && !scripts.dev) issues.push({ severity: 'high', text: 'No "start" or "dev" script' });
        if (!scripts.test || scripts.test.indexOf('no test specified') !== -1) issues.push({ severity: 'high', text: 'No test script \u2014 deploying without tests' });
        if (!pkg.name) issues.push({ severity: 'low', text: 'Missing "name" field' });
        if (!pkg.version) issues.push({ severity: 'low', text: 'Missing "version" field' });
        if (!pkg.description) issues.push({ severity: 'low', text: 'Missing "description"' });
        if (!pkg.license) issues.push({ severity: 'low', text: 'Missing "license"' });
      } catch(e) {
        issues.push({ severity: 'high', text: 'package.json is invalid JSON' });
      }
    }

    function scanPackageJson() {
      var input = document.getElementById('pkg-input').value.trim();
      if (!input) {
        var results = document.getElementById('scan-results');
        results.classList.remove('hidden');
        results.innerHTML = '<p class="text-red-400">Paste a valid package.json.</p>';
        return;
      }
      var issues = [];
      checkPackageJson(input, issues);
      renderResults(issues, 'package.json scan');
    }

    async function scanGitHub() {
      var input = document.getElementById('github-input').value.trim();
      var results = document.getElementById('scan-results');
      results.classList.remove('hidden');

      var match = input.match(/github\.com\/([^\/]+)\/([^\/\s]+)/);
      if (!match) {
        results.innerHTML = '<p class="text-red-400">Paste a valid GitHub URL (e.g., https://github.com/user/repo)</p>';
        return;
      }

      var owner = match[1];
      var repoName = match[2].replace(/\.git$/, '');
      results.innerHTML = '<p class="text-text-dim animate-pulse">Scanning ' + owner + '/' + repoName + '...</p>';

      var issues = [];

      async function fetchFile(path) {
        var branches = ['main', 'master'];
        for (var b = 0; b < branches.length; b++) {
          try {
            var res = await fetch('https://raw.githubusercontent.com/' + owner + '/' + repoName + '/' + branches[b] + '/' + path);
            if (res.ok) return await res.text();
          } catch(e) {}
        }
        return null;
      }

      var fetched = await Promise.all([
        fetchFile('package.json'),
        fetchFile('tsconfig.json'),
        fetchFile('.gitignore'),
        fetchFile('README.md')
      ]);
      var pkgRaw = fetched[0];
      var tsconfig = fetched[1];
      var gitignore = fetched[2];
      var readme = fetched[3];

      var hasCI = false;
      try {
        var ciRes = await fetch('https://api.github.com/repos/' + owner + '/' + repoName + '/contents/.github/workflows');
        if (ciRes.ok) hasCI = true;
      } catch(e) {}

      if (!pkgRaw) {
        issues.push({ severity: 'high', text: 'No package.json found' });
      } else {
        checkPackageJson(pkgRaw, issues);
      }

      if (!gitignore) {
        issues.push({ severity: 'critical', text: 'No .gitignore file' });
      } else {
        if (gitignore.indexOf('node_modules') === -1) issues.push({ severity: 'high', text: 'node_modules not in .gitignore' });
        if (gitignore.indexOf('.env') === -1) issues.push({ severity: 'critical', text: '.env not in .gitignore \u2014 secrets may be exposed' });
      }

      if (!readme) issues.push({ severity: 'medium', text: 'No README.md' });
      if (!hasCI) issues.push({ severity: 'medium', text: 'No CI/CD configuration (.github/workflows/)' });

      if (tsconfig) {
        try {
          var cleaned = tsconfig.replace(/\/\/.*$/gm, '').replace(/\/\*[\s\S]*?\*\//g, '');
          if (cleaned.indexOf('"strict": true') === -1 && cleaned.indexOf('"strict":true') === -1) {
            issues.push({ severity: 'low', text: 'TypeScript strict mode not enabled' });
          }
        } catch(e) {}
      }

      renderResults(issues, owner + '/' + repoName);
    }
  </script>
</Layout>
